# Environment variables for diplomMagistrate
#
# Версия: 1.1
# Обновлено: 2026-04-10

# === Dataset ===
DATASET_PATH=data/terms.csv

# === Embedding model ===
EMBEDDING_MODEL=ai-forever/sbert_large_nlu_ru

# === TF-IDF thresholds ===
IDF_THRESHOLD=0.0
ZSCORE_THRESHOLD=3.0

# === Similarity metric ===
SIMILARITY_METRIC=cosine

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
CACHE_TTL=3600

# === Device for model (cpu, cuda, mps) ===
DEVICE=cpu

# === Logging ===
LOG_LEVEL=INFO

# === RuWordNet (optional) ===
# RUWORDNET_DB_PATH=/path/to/ruwordnet.db
